Pr><w:br/><w:t>4.2 performance efficiency;</w:t></w:r><w:r w:rsidRPr="00820505"><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/><w:sz w:val="22"/><w:szCs w:val="22"/></w:rPr><w:br/><w:t>4.3 compatibility;</w:t></w:r><w:r w:rsidRPr="00820505"><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/><w:sz w:val="22"/><w:szCs w:val="22"/></w:rPr><w:br/><w:t>4.4 interaction capability (usability);</w:t></w:r><w:r w:rsidRPr="00820505"><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/><w:sz w:val="22"/><w:szCs w:val="22"/></w:rPr><w:br/><w:t>4.5 reliability;</w:t></w:r><w:r w:rsidRPr="00820505"><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/><w:sz w:val="22"/><w:szCs w:val="22"/></w:rPr><w:br/><w:t>4.6 security;</w:t></w:r><w:r w:rsidRPr="00820505"><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/><w:sz w:val="22"/><w:szCs w:val="22"/></w:rPr><w:br/><w:t>4.7 maintainability;</w:t></w:r><w:r w:rsidRPr="00820505"><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/><w:sz w:val="22"/><w:szCs w:val="22"/></w:rPr><w:br/></w:r><w:r w:rsidRPr="00820505"><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/><w:sz w:val="22"/><w:szCs w:val="22"/></w:rPr><w:lastRenderedPageBreak/><w:t>4.8 flexibility; and</w:t></w:r><w:r w:rsidRPr="00820505"><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/><w:sz w:val="22"/><w:szCs w:val="22"/></w:rPr><w:br/><w:t>4.9 safety.</w:t></w:r></w:p><w:p w14:paraId="4C2B2D07" w14:textId="700F2998" w:rsidR="00820505" w:rsidRPr="00820505" w:rsidRDefault="00820505" w:rsidP="00820505"><w:pPr><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/><w:b/><w:bCs/><w:sz w:val="22"/><w:szCs w:val="22"/></w:rPr></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/><w:b/><w:bCs/><w:sz w:val="22"/><w:szCs w:val="22"/></w:rPr><w:t>SCOPE AND LIMITATION</w:t></w:r></w:p><w:p w14:paraId="1501F71A" w14:textId="77777777" w:rsidR="00820505" w:rsidRPr="00820505" w:rsidRDefault="00820505" w:rsidP="00820505"><w:pPr><w:pStyle w:val="NormalWeb"/><w:ind w:left="720"/><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/><w:sz w:val="22"/><w:szCs w:val="22"/></w:rPr></w:pPr><w:r w:rsidRPr="00820505"><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/><w:sz w:val="22"/><w:szCs w:val="22"/></w:rPr><w:t xml:space="preserve">The proposed </w:t></w:r><w:r w:rsidRPr="00820505"><w:rPr><w:rStyle w:val="Strong"/><w:rFonts w:ascii="Arial" w:eastAsiaTheme="majorEastAsia" w:hAnsi="Arial" w:cs="Arial"/><w:sz w:val="22"/><w:szCs w:val="22"/></w:rPr><w:t>Integrated Sales Tracking and Inventory Management System for PC Alley</w:t></w:r><w:r w:rsidRPr="00820505"><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/><w:sz w:val="22"/><w:szCs w:val="22"/></w:rPr><w:t xml:space="preserve"> focuses on improving the management of sales transactions and inventory processes within the business. The system provides a centralized platform where sales data can be recorded, inventory levels can be monitored, and reports can be generated efficiently. Key features of the system include sales transaction recording, inventory tracking, product management, report generation, and stock level monitoring with notifications such as low-stock alerts.</w:t></w:r></w:p><w:p w14:paraId="07715D11" w14:textId="77777777" w:rsidR="00820505" w:rsidRPr="00820505" w:rsidRDefault="00820505" w:rsidP="00820505"><w:pPr><w:pStyle w:val="NormalWeb"/><w:ind w:left="720"/><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/><w:sz w:val="22"/><w:szCs w:val="22"/></w:rPr></w:pPr><w:r w:rsidRPr="00820505"><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/><w:sz w:val="22"/><w:szCs w:val="22"/></w:rPr><w:t xml:space="preserve">The system is designed to ensure </w:t></w:r><w:r w:rsidRPr="00820505"><w:rPr><w:rStyle w:val="Strong"/><w:rFonts w:ascii="Arial" w:eastAsiaTheme="majorEastAsia" w:hAnsi="Arial" w:cs="Arial"/><w:sz w:val="22"/><w:szCs w:val="22"/></w:rPr><w:t>data accuracy and integrity</w:t></w:r><w:r w:rsidRPr="00820505"><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/><w:sz w:val="22"/><w:szCs w:val="22"/></w:rPr><w:t>, particularly by preserving historical sales records. Each transaction will store its own product price at the time of purchase, preventing changes in product pricing from affecting past records. This ensures that financial reports and sales analysis remain accurate and reliable.</w:t></w:r></w:p><w:p w14:paraId="230C06A1" w14:textId="77777777" w:rsidR="00820505" w:rsidRPr="00820505" w:rsidRDefault="00820505" w:rsidP="00820505"><w:pPr><w:pStyle w:val="NormalWeb"/><w:ind w:left="720"/><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/><w:sz w:val="22"/><w:szCs w:val="22"/></w:rPr></w:pPr><w:r w:rsidRPr="00820505"><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/><w:sz w:val="22"/><w:szCs w:val="22"/></w:rPr><w:t xml:space="preserve">The primary users of the system are the </w:t></w:r><w:r w:rsidRPr="00820505"><w:rPr><w:rStyle w:val="Strong"/><w:rFonts w:ascii="Arial" w:eastAsiaTheme="majorEastAsia" w:hAnsi="Arial" w:cs="Arial"/><w:sz w:val="22"/><w:szCs w:val="22"/></w:rPr><w:t>business owner/manager and store employees</w:t></w:r><w:r w:rsidRPr="00820505"><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/><w:sz w:val="22"/><w:szCs w:val="22"/></w:rPr><w:t>, with different access levels to ensure proper control and data security. Only authorized personnel will be allowed to access and manage sensitive business data, ensuring confidentiality and integrity of information.</w:t></w:r></w:p><w:p w14:paraId="1F6723D5" w14:textId="77777777" w:rsidR="00820505" w:rsidRPr="00820505" w:rsidRDefault="00820505" w:rsidP="00820505"><w:pPr><w:pStyle w:val="NormalWeb"/><w:ind w:left="720"/><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/><w:sz w:val="22"/><w:szCs w:val="22"/></w:rPr></w:pPr><w:r w:rsidRPr="00820505"><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/><w:sz w:val="22"/><w:szCs w:val="22"/></w:rPr><w:t xml:space="preserve">However, the system has certain limitations. It is designed exclusively for </w:t></w:r><w:r w:rsidRPr="00820505"><w:rPr><w:rStyle w:val="Strong"/><w:rFonts w:ascii="Arial" w:eastAsiaTheme="majorEastAsia" w:hAnsi="Arial" w:cs="Arial"/><w:sz w:val="22"/><w:szCs w:val="22"/></w:rPr><w:t>PC Alley</w:t></w:r><w:r w:rsidRPr="00820505"><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/><w:sz w:val="22"/><w:szCs w:val="22"/></w:rPr><w:t xml:space="preserve"> and is not intended for use by other businesses or industries. The system focuses only on </w:t></w:r><w:r w:rsidRPr="00820505"><w:rPr><w:rStyle w:val="Strong"/><w:rFonts w:ascii="Arial" w:eastAsiaTheme="majorEastAsia" w:hAnsi="Arial" w:cs="Arial"/><w:sz w:val="22"/><w:szCs w:val="22"/></w:rPr><w:t>sales and inventory management</w:t></w:r><w:r w:rsidRPr="00820505"><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/><w:sz w:val="22"/><w:szCs w:val="22"/></w:rPr><w:t xml:space="preserve"> and does not include advanced accounting features such as tax computation, payroll, or full financial management. Additionally, the system does not support online payment processing or e-commerce functionality, as it is intended for in-store transactions only.</w:t></w:r></w:p><w:p w14:paraId="52D677F2" w14:textId="77777777" w:rsidR="00820505" w:rsidRPr="00820505" w:rsidRDefault="00820505" w:rsidP="00820505"><w:pPr><w:pStyle w:val="NormalWeb"/><w:ind w:left="720"/><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/><w:sz w:val="22"/><w:szCs w:val="22"/></w:rPr></w:pPr><w:r w:rsidRPr="00820505"><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/><w:sz w:val="22"/><w:szCs w:val="22"/></w:rPr><w:t xml:space="preserve">The respondents of the study include the </w:t></w:r><w:r w:rsidRPr="00820505"><w:rPr><w:rStyle w:val="Strong"/><w:rFonts w:ascii="Arial" w:eastAsiaTheme="majorEastAsia" w:hAnsi="Arial" w:cs="Arial"/><w:sz w:val="22"/><w:szCs w:val="22"/></w:rPr><w:t>PC Alley owner and employees</w:t></w:r><w:r w:rsidRPr="00820505"><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/><w:sz w:val="22"/><w:szCs w:val="22"/></w:rPr><w:t>, who will evaluate the system based on usability, efficiency, and reliability. Data will be gathered through surveys and interviews to assess the system’s effectiveness in improving business operations and resolving the identified issues. The findings will help determine whether the system meets user needs and contributes to more accurate and efficient sales and inventory management.</w:t></w:r></w:p><w:p w14:paraId="50809557" w14:textId="77777777" w:rsidR="00820505" w:rsidRPr="003434DA" w:rsidRDefault="00820505" w:rsidP="00820505"><w:pPr><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/><w:sz w:val="22"/><w:szCs w:val="22"/></w:rPr></w:pPr></w:p><w:p w14:paraId="6D24EBC7" w14:textId="77777777" w:rsidR="003434DA" w:rsidRPr="003434DA" w:rsidRDefault="003434DA" w:rsidP="003434DA"><w:pPr><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/><w:b/><w:bCs/><w:sz w:val="22"/><w:szCs w:val="22"/><w:lang w:val="en-PH"/></w:rPr></w:pPr></w:p><w:sectPr w:rsidR="003434DA" w:rsidRPr="003434DA"><w:pgSz w:w="11906" w:h="16838"/><w:pgMar w:top="1440" w:right="1440" w:bottom="1440" w:left="1440" w:header="708" w:footer="708" w:gutter="0"/><w:cols w:space="708"/><w:docGrid w:linePitch="360"/></w:sectPr></w:body></w:document>